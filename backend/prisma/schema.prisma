generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Evento {
  id         String   @id @default(uuid())
  sessionId  String
  tipo       String
  produtoId  String?
  afiliadoId String?
  pedidoId   String?
  valor      Decimal?
  status     String?
  createdAt  DateTime @default(now())
}

model Usuario {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}