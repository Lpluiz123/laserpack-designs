generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Evento {
  id           String   @id @default(uuid())
  sessionId    String
  tipo         String
  produtoId    String?
  afiliadoId   String?
  valor        Decimal?
  status       String?
  createdAt    DateTime @default(now())
}